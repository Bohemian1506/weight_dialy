<% content_for :title, t(".title") %>

<div class="sketch-page-narrow" style="max-width: 40rem; padding-left: 16px; padding-right: 16px;">

  <h1 class="sketch-hh" style="margin-bottom: 4px;"><%= t(".h1") %></h1>
  <p class="sketch-small" style="margin-bottom: 16px;"><%= t(".last_updated") %></p>

  <p class="sketch-body-text" style="margin-bottom: 24px;">
    <%= t(".intro") %>
  </p>

  <div class="sketch-box" style="margin-bottom: 20px;">
    <h2 class="sketch-h" style="margin-bottom: 8px;"><%= t(".sections.overview.title") %></h2>
    <p class="sketch-body-text">
      <%= t(".sections.overview.body") %>
    </p>
  </div>

  <div class="sketch-box" style="margin-bottom: 20px;">
    <h2 class="sketch-h" style="margin-bottom: 8px;"><%= t(".sections.prohibitions.title") %></h2>
    <p class="sketch-body-text" style="margin-bottom: 8px;"><%= t(".sections.prohibitions.lead") %></p>
    <ul class="sketch-body-text" style="padding-left: 1.5em;">
      <% t(".sections.prohibitions.items").each do |item| %>
        <li><%= item %></li>
      <% end %>
    </ul>
  </div>

  <div class="sketch-box" style="margin-bottom: 20px;">
    <h2 class="sketch-h" style="margin-bottom: 8px;"><%= t(".sections.disclaimer.title") %></h2>
    <p class="sketch-body-text" style="margin-bottom: 8px;">
      <%= t(".sections.disclaimer.body_a") %>
    </p>
    <p class="sketch-body-text">
      <%= t(".sections.disclaimer.body_b") %>
    </p>
  </div>

  <div class="sketch-box" style="margin-bottom: 20px;">
    <h2 class="sketch-h" style="margin-bottom: 8px;"><%= t(".sections.change_termination.title") %></h2>
    <p class="sketch-body-text">
      <%= t(".sections.change_termination.body") %>
    </p>
  </div>

  <div class="sketch-box" style="margin-bottom: 20px;">
    <h2 class="sketch-h" style="margin-bottom: 8px;"><%= t(".sections.amendment.title") %></h2>
    <p class="sketch-body-text">
      <%= t(".sections.amendment.body") %>
    </p>
  </div>

  <div class="sketch-box" style="margin-bottom: 20px;">
    <h2 class="sketch-h" style="margin-bottom: 8px;"><%= t(".sections.governing_law.title") %></h2>
    <p class="sketch-body-text">
      <%= t(".sections.governing_law.body") %>
    </p>
  </div>

  <div class="sketch-box" style="margin-bottom: 20px;">
    <h2 class="sketch-h" style="margin-bottom: 8px;"><%= t(".sections.contact.title") %></h2>
    <p class="sketch-body-text">
      <%= t(".sections.contact.body") %>
    </p>
    <p class="sketch-body-text" style="margin-top: 8px;">
      <%= mail_to "weightdaily3@gmail.com", "weightdaily3@gmail.com", style: "color: var(--ink); text-decoration: underline;" %>
    </p>
  </div>

  <%# 改訂履歴セクション (= Issue #91): 1 行詰込から `<h2>` + `<ul>` 構造化に。
      table でなく ul を選んだ理由 = 1 軸 (= 時系列のみ) なので何件あっても ul が筋、軸数 ≥ 2 で初めて table 検討
      (= 「table 使いたい衝動は件数でなく軸数で殺す」、Issue #178 本文に判断ルール追記済)。
      他セクションと整合させるため「8. 改訂履歴」 として番号付き昇格 + sketch-box 包み。 %>
  <div class="sketch-box" style="margin-bottom: 20px;">
    <h2 class="sketch-h" style="margin-bottom: 8px;"><%= t(".sections.revision_history.title") %></h2>
    <ul class="sketch-small" style="color: var(--ink-2); margin: 0; padding-left: 1.2em; line-height: 1.6;">
      <%# Rails i18n は yml の hash キーを Symbol で返すため item[:date] / item[:description] でアクセス (= YAML.safe_load の String キー挙動と異なる、後続実装者向けメモ)。 %>
      <% t(".sections.revision_history.items").each do |item| %>
        <li><strong><%= item[:date] %></strong> — <%= item[:description] %></li>
      <% end %>
    </ul>
  </div>

</div>
